    name: "Merchant Center", 
    customSvg: `<svg viewBox="0 0 24 24" fill="#4285F4"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/></svg>`,
    color: "4285F4" 
  },
  { 
    name: "Conversion Tracking", 
    customSvg: `<svg viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
    color: "FFFFFF" 
  }
];

const chunkSize = Math.ceil(skills.length / 4);
const row1 = skills.slice(0, chunkSize);
const row2 = skills.slice(chunkSize, chunkSize * 2);
const row3 = skills.slice(chunkSize * 2, chunkSize * 3);
const row4 = skills.slice(chunkSize * 3);
---

<div class="w-full">
  {/* DESKTOP VIEW */}
  <div id="desktop-skills-container" class="hidden md:flex relative w-full max-w-4xl mx-auto py-20 overflow-visible user-select-none flex-wrap justify-center gap-6 lg:gap-8 perspective-1000">
    {skills.map((skill) => (
      <div
        class="skill-item relative flex items-center justify-center w-14 h-14 lg:w-16 lg:h-16 rounded-full will-change-transform group"
        data-color={`#${skill.color}`}
        style="filter: grayscale(100%) opacity(0.4);"
      >
        {skill.customSvg ? (
           <div class="w-10 h-10 lg:w-12 lg:h-12 pointer-events-none" set:html={skill.customSvg} />
        ) : (
           <img 
             src={`https://cdn.simpleicons.org/${skill.slug}/${skill.color}`} 
             alt={skill.name} 
             class="w-10 h-10 lg:w-12 lg:h-12 object-contain pointer-events-none"
           />
        )}
        <span class="absolute -top-12 px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider text-white bg-zinc-900 border border-white/20 rounded-md opacity-0 transition-opacity duration-200 pointer-events-none whitespace-nowrap group-hover:opacity-100 z-[9999] shadow-2xl">
          {skill.name}
        </span>
      </div>
    ))}
  </div>

  {/* MOBILE VIEW */}
  <div class="flex md:hidden w-full py-10 overflow-hidden flex-col gap-8 relative">
    <div class="absolute inset-y-0 left-0 w-12 bg-gradient-to-r from-[#0a0a0a] to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-12 bg-gradient-to-l from-[#0a0a0a] to-transparent z-10 pointer-events-none"></div>

    {[row1, row2, row3, row4].map((row, i) => (
      <div class={`flex w-max ${i % 2 === 0 ? 'animate-marquee-left' : 'animate-marquee-right'}`}>
        <div class="flex gap-8 pr-8 items-center">
          {row.map((skill) => (
            <div class="flex flex-col items-center gap-2 w-16">
              <div class="w-8 h-8 flex items-center justify-center opacity-80">
                {skill.customSvg ? <div class="w-full h-full" set:html={skill.customSvg} /> : <img src={`https://cdn.simpleicons.org/${skill.slug}/${skill.color}`} alt={skill.name} class="w-full h-full object-contain" />}
              </div>
              <span class="text-[8px] uppercase tracking-widest text-gray-500 whitespace-nowrap text-center">{skill.name}</span>
            </div>
          ))}
        </div>
        <div class="flex gap-8 pr-8 items-center">
          {row.map((skill) => (
            <div class="flex flex-col items-center gap-2 w-16">
              <div class="w-8 h-8 flex items-center justify-center opacity-80">
                {skill.customSvg ? <div class="w-full h-full" set:html={skill.customSvg} /> : <img src={`https://cdn.simpleicons.org/${skill.slug}/${skill.color}`} alt={skill.name} class="w-full h-full object-contain" />}
              </div>
              <span class="text-[8px] uppercase tracking-widest text-gray-500 whitespace-nowrap text-center">{skill.name}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  const container = document.getElementById('desktop-skills-container');
  if (container) {
    const items = container.querySelectorAll('.skill-item');
    
    // CONFIGURATION
    const config = { 
      maxScale: 1.8, 
      baseScale: 1.0, 
      influenceRadius: 100, // Reduced radius for "tighter" color focus
      damping: 0.2          // Faster damping for snappier reset
    };

    let targetScales = new Array(items.length).fill(config.baseScale);
    let currentScales = new Array(items.length).fill(config.baseScale);
    let animationFrameId = null;

    function animate() {
      let needsUpdate = false;

      items.forEach((item, index) => {
        const diff = targetScales[index] - currentScales[index];
        
        if (Math.abs(diff) > 0.001) {
          currentScales[index] += diff * config.damping;
          needsUpdate = true;
        } else {
          currentScales[index] = targetScales[index]; 
        }

        // Apply Transform
        item.style.transform = `scale(${currentScales[index]})`;
        item.style.zIndex = Math.round(currentScales[index] * 100).toString();

        // LOGIC: COLOR TRANSITION (JS ONLY)
        // Only trigger color if the icon is significantly magnified
        if (currentScales[index] > config.baseScale + 0.15) {
          const color = item.getAttribute('data-color');
          // Smoothly fade from grayscale to color based on magnification scale
          const progress = (currentScales[index] - (config.baseScale + 0.15)) / (config.maxScale - (config.baseScale + 0.15));
          const grayValue = 100 - (progress * 100);
          const opacityValue = 0.4 + (progress * 0.6);
          
          item.style.filter = `grayscale(${grayValue}%) opacity(${opacityValue}) drop-shadow(0 0 10px ${color}60)`;
        } else {
          // Absolute reset
          item.style.filter = "grayscale(100%) opacity(0.4)";
        }
      });

      if (needsUpdate) {
        animationFrameId = requestAnimationFrame(animate);
      } else {
        animationFrameId = null; 
      }
    }

    container.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect();
      const mouseX = e.clientX - rect.left;
      const mouseY = e.clientY - rect.top;

      items.forEach((item, index) => {
        const itemRect = item.getBoundingClientRect();
        const itemCenterX = itemRect.left + itemRect.width / 2 - rect.left;
        const itemCenterY = itemRect.top + itemRect.height / 2 - rect.top;
        const distance = Math.sqrt(Math.pow(mouseX - itemCenterX, 2) + Math.pow(mouseY - itemCenterY, 2));

        if (distance < config.influenceRadius) {
          const ratio = 1 - (distance / config.influenceRadius);
          const scaleBoost = Math.sin(ratio * Math.PI / 2) * (config.maxScale - config.baseScale);
          targetScales[index] = config.baseScale + scaleBoost;
        } else {
          targetScales[index] = config.baseScale;
        }
      });
      if (!animationFrameId) animate();
    });

    container.addEventListener('mouseleave', () => {
      targetScales.fill(config.baseScale);
      if (!animationFrameId) animate();
    });
  }
</script>

<style>
  .perspective-1000 { perspective: 1000px; }
  .user-select-none { user-select: none; }
  @keyframes marqueeLeft { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  @keyframes marqueeRight { 0% { transform: translateX(-50%); } 100% { transform: translateX(0); } }
  .animate-marquee-left { animation: marqueeLeft 30s linear infinite; }
  .animate-marquee-right { animation: marqueeRight 30s linear infinite; }
  
  /* Remove Tailwind hover transitions to prevent flickering */
  .skill-item {
     transition: none; 
  }
</style>