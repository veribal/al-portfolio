    customSvg: `<svg viewBox="0 0 24 24" fill="#1572B6"><path d="M1.5 0h21l-1.91 21.563L11.977 24l-8.564-2.438L1.5 0zm17.09 4.149l-.298-3.34H3.892l.24 2.684h13.91l-.145 1.625H4.275l.24 2.684h13.29l-.657 7.355-5.17 1.436-5.17-1.436-.33-3.69H3.79l.52 5.827 7.667 2.126 7.667-2.126 1.05-11.758z"/></svg>`,
    color: "1572B6" 
  },
  { name: "JavaScript", slug: "javascript", color: "F7DF1E" },
  { name: "React.js", slug: "react", color: "61DAFB" },
  { name: "Node.js", slug: "nodedotjs", color: "339933" },
  { name: "Express.js", slug: "express", color: "FFFFFF" },
  { name: "MongoDB", slug: "mongodb", color: "47A248" },
