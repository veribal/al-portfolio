  { name: "Tailwind", slug: "tailwindcss", color: "06B6D4" },
  { name: "WordPress", slug: "wordpress", color: "21759A" },

  // --- Data Analysis ---
  { name: "SQL", slug: "mysql", color: "4479A1" },
  { 
    name: "Excel", 
    customSvg: `<svg viewBox="0 0 24 24" fill="#217346"><path d="M23 1.5q.41 0 .7.3.3.29.3.7v19q0 .41-.3.7-.29.3-.7.3H7q-.41 0-.7-.3-.3-.29-.3-.7V18H1q-.41 0-.7-.3-.3-.29-.3-.7V7q0-.41.3-.7Q1 6 1.41 6H6V2.5q0-.41.3-.7.29-.3.7-.3zM6 13.28l1.42 2.66h2.14l-2.45-3.94 2.3-3.86h-2.1L6 10.74L4.68 8.14H2.54l2.3 3.86-2.45 3.94h2.14zM22 3.5h-5v3h5zm0 5h-5v3h5zm0 5h-5v3h5zm0 5h-5v3h5zm-7-15h-4v3h4zm0 5h-4v3h4zm0 5h-4v3h4zm0 5h-4v3h4z"/></svg>`,
    color: "217346" 
  },
  { name: "Google Sheets", slug: "googlesheets", color: "34A853" },
  { 
    name: "Power BI", 
    customSvg: `<svg viewBox="0 0 24 24" fill="#F2C811"><path d="M10.462 6.014h2.893v16.923h-2.893zM4.776 11.21h2.893v11.727H4.776zM16.147 1.063h2.894v21.874h-2.894z"/></svg>`,
    color: "F2C811" 
