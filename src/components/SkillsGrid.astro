  { name: "Looker Studio", slug: "looker", color: "4285F4" },
  { name: "GA4", slug: "googleanalytics", color: "E37400" },
  { name: "Python", slug: "python", color: "3776AB" },

  // --- Digital Marketing ---
  { name: "Tag Manager", slug: "googletagmanager", color: "246FDB" },
  { name: "Google Ads", slug: "googleads", color: "4285F4" },
  { name: "Search Console", slug: "googlesearchconsole", color: "4585F4" },
  { name: "SEMRush", slug: "semrush", color: "EC5627" },
  { name: "Shopify", slug: "shopify", color: "7AB55C" },
  { name: "Hubspot", slug: "hubspot", color: "FF7A59" },
  
