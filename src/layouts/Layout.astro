---
// THIS LINE IS CRUCIAL - It forces Tailwind to load
import '../styles/global.css'; 

interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-[#0a0a0a] text-white font-sans antialiased selection:bg-red-500 selection:text-white">
		<slot />
	</body>
</html>

<style is:global>
  /* Base Tailwind import if Vite plugin fails */
  @import "tailwindcss";
</style>