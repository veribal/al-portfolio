---
import Layout from '../layouts/Layout.astro';
import profileImage from '../assets/photos/profile.png';
import SkillsGrid from '../components/SkillsGrid.astro';

// We define your menu items and their target IDs here
const menuItems = [
  { name: 'about me', link: '#about' },
  { name: 'work experience', link: '#experience' },
  { name: 'personal skills', link: '#skills' },
  { name: 'portfolio', link: '#portfolio' },
  { name: 'services', link: '#services' },
  { name: 'contact', link: '#contact' }
];
---

<Layout title="Alberry Jed Rivera | Portfolio">
  <main class="bg-[#0a0a0a] text-[#f4f4f4] font-sans selection:bg-[#ff4d4d] selection:text-white overflow-x-hidden">
    
    {/* SECTION 1: HERO */}
    <section id="hero" class="min-h-screen relative flex flex-col justify-center px-8 md:px-10 lg:px-32 border-b border-white/5 pt-24 md:pt-0">
      
      <div class="absolute top-8 md:top-12 left-8 md:left-10 lg:left-32 inline-flex items-center gap-3 px-4 py-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm z-20">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        <span class="text-[10px] uppercase tracking-[0.2em] font-bold opacity-80 mt-[1px]">Available for new projects</span>
      </div>

      <div class="relative z-10 max-w-6xl mt-10 md:mt-20">
        <h1 class="text-[14vw] md:text-[12vw] lg:text-[7vw] font-medium leading-[0.9] tracking-tighter">
          Full Stack <br/> Web Development, <br/> Data Analysis & <br/> Digital Marketing.
        </h1>
      </div>

      <div class="hidden lg:flex absolute right-20 top-0 bottom-0 flex-col items-center py-12 z-20">
        <div class="text-[#ff4d4d] text-5xl font-thin leading-none">+</div>
        <div class="flex-1 w-[1px] bg-white/20 my-8"></div>
        <div class="[writing-mode:vertical-rl] rotate-180 text-sm tracking-[0.4em] uppercase opacity-70 whitespace-nowrap">
          Alberry Jed Rivera
        </div>
      </div>

      <div class="mt-10 flex items-center gap-8">
      <a 
        href="/Alberry-Jed-Rivera-Resume.pdf" 
        download
        class="group/resume relative px-8 py-3 rounded-full border border-white/20 text-xs uppercase tracking-[0.2em] font-bold overflow-hidden transition-all hover:border-[#ff4d4d]"
      >
        <span class="relative z-10 group-hover/resume:text-white">Download CV</span>
        <div class="absolute inset-0 bg-[#ff4d4d] translate-y-[101%] group-hover/resume:translate-y-0 transition-transform duration-300 ease-out"></div>
      </a>
      
      <span class="text-[10px] uppercase tracking-[0.3em] opacity-40 hidden md:block">
        Scroll to explore
      </span>
    </div>
    </section>

    {/* SECTION 2: TABLE OF CONTENTS */}
    <section id="toc" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="mt-8 md:mt-32 text-[#ff4d4d] text-5xl font-thin leading-none mb-8 md:mb-16 relative md:-left-[17px]">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase leading-loose">
          Table of <br/> Contents
        </div>
      </aside>

      <div class="w-full md:w-2/3 p-8 md:p-10 lg:p-32 flex flex-col justify-center">
        <p class="text-lg md:text-xl font-light text-gray-400 leading-relaxed max-w-2xl mb-16 md:mb-24">
          Full spectrum of technical and marketing solutions to aspiring and established brands. Create and implement effective strategies that boost sales and engagement. Business owners can focus on running their operations while I build the systems, analyze the data, and manage the digital marketing needs.
        </p>

        <ul class="space-y-6 text-3xl md:text-4xl lg:text-6xl font-light tracking-tight">
          {menuItems.map((item) => (
            <li>
              <a href={item.link} class="group flex items-center gap-6 md:gap-8 hover:text-white text-gray-500 transition-colors w-fit">
                <span class="text-white/10 font-mono text-4xl md:text-5xl group-hover:text-white transition-colors font-thin">+</span> 
                <span class="group-hover:translate-x-4 transition-transform duration-500">{item.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* SECTION 3: ABOUT ME */}
    <section id="about" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5 justify-center">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="hidden md:block absolute top-32 text-[#ff4d4d] text-5xl font-thin leading-none -left-[17px]">+</div>
        <div class="md:hidden text-[#ff4d4d] text-5xl font-thin leading-none mb-4">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase">About me</div>
      </aside>

      <div class="w-full md:w-2/3 p-8 md:p-10 lg:p-32 flex flex-col lg:flex-row gap-12 md:gap-20 items-center">
        
        <div class="flex-1 order-2 lg:order-1">
          <div class="flex items-start gap-4 mb-10 md:mb-16">
            <div class="w-3 h-3 bg-[#ff4d4d] mt-2 flex-shrink-0"></div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight leading-tight">
              Algorithm Precision. <br/> Creative Fix. <br/> Breakthrough Results.
            </h2>
          </div>
          <p class="text-base md:text-lg font-light text-gray-400 leading-relaxed">
            A multidisciplinary professional who can manage the technical, analytical, and marketing aspects of your business. Planning and delivering full-stack solutions, analyzing market trends, and executing campaigns that propel your brand to new heights.
          </p>
        </div>

        <div class="w-full lg:w-96 flex-shrink-0 order-1 lg:order-2">
          <div class="aspect-[3/4] bg-zinc-900 overflow-hidden relative group">
            <img 
              src={profileImage.src} 
              alt="Alberry Jed Rivera" 
              class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700" 
            />
          </div>
          <h3 class="text-2xl md:text-3xl font-medium mt-6">Alberry Jed Rivera</h3>
          <p class="text-xs md:text-sm opacity-60 tracking-widest uppercase mt-2">Web Dev / Data / Marketing</p>
        </div>

      </div>
    </section>

    {/* SECTION 4: EXPERIENCE */}
    <section id="experience" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5 justify-center">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="hidden md:block absolute top-32 text-white text-5xl font-thin leading-none -left-[17px]">+</div>
        <div class="md:hidden text-white text-5xl font-thin leading-none mb-4">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase">Experience</div>
      </aside>

      <div class="w-full md:w-2/3 p-8 md:p-10 lg:p-32 flex flex-col justify-center">
        <div class="space-y-12 md:space-y-16">
          
          <div class="flex items-start gap-6 md:gap-8">
            <div class="text-[#ff4d4d] text-3xl md:text-4xl font-thin mt-1">+</div>
            <div>
              <h3 class="text-2xl md:text-3xl lg:text-4xl font-medium mb-2">Administrative Growth Assistant</h3>
              <p class="text-base md:text-lg opacity-60 font-light">Talentpop, 2026 – Present</p>
            </div>
          </div>

          <div class="flex items-start gap-6 md:gap-8">
            <div class="text-[#ff4d4d] text-3xl md:text-4xl font-thin mt-1">+</div>
            <div>
              <h3 class="text-2xl md:text-3xl lg:text-4xl font-medium mb-2">Google Ads Strategist</h3>
              <p class="text-base md:text-lg opacity-60 font-light">Concentrix, 2024 – 2026</p>
            </div>
          </div>

		  <div class="flex items-start gap-6 md:gap-8">
            <div class="text-[#ff4d4d] text-3xl md:text-4xl font-thin mt-1">+</div>
            <div>
              <h3 class="text-2xl md:text-3xl lg:text-4xl font-medium mb-2">Business Development Associate</h3>
              <p class="text-base md:text-lg opacity-60 font-light">Accenture, 2021 – 2024</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    {/* PLACEHOLDER SECTIONS (So the links work!) */}
    {/* SECTION 5: PERSONAL SKILLS */}
    <section id="skills" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5 justify-center">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="hidden md:block absolute top-32 text-[#ff4d4d] text-5xl font-thin leading-none -left-[17px]">+</div>
        <div class="md:hidden text-[#ff4d4d] text-5xl font-thin leading-none mb-4">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase">Personal Skills</div>
      </aside>

      <div class="w-full md:w-2/3 p-8 md:p-10 lg:p-32 flex flex-col justify-center items-center">
        <div class="max-w-3xl text-center mb-16">
           <h2 class="text-3xl md:text-4xl font-medium mb-6">A Full-Stack Arsenal.</h2>
           <p class="text-gray-400 font-light leading-relaxed">
             My expertise spans the entire digital lifecycle. From architecting robust web applications and analyzing complex datasets to executing high-ROI marketing campaigns, I have the right tool for every challenge.
           </p>
        </div>

        <SkillsGrid />
        
      </div>
    </section>
    
    <section id="portfolio" class="min-h-[50vh] flex items-center justify-center border-b border-white/5 text-white/30 text-2xl font-light">
    {/* ======================================================
        SECTION 6: FEATURED PORTFOLIO
        ====================================================== */}
    <section id="portfolio" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5 justify-center">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="absolute top-32 text-[#ff4d4d] text-5xl font-thin leading-none -left-[17px] hidden md:block">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase">Selected Work</div>
      </aside>

      <div class="w-full md:w-2/3 p-0 md:p-0 flex flex-col">
        
        <div class="group relative w-full flex flex-col lg:flex-row border-b border-white/5 hover:bg-white/[0.02] transition-colors duration-500">
          <div class="flex-1 p-8 md:p-16 lg:p-24 flex flex-col justify-center">
            <span class="text-[#ff4d4d] font-mono text-sm mb-6 block tracking-widest uppercase">01 / Lead Generation</span>
            <h3 class="text-4xl md:text-5xl lg:text-6xl font-medium tracking-tighter mb-8 leading-tight">
              Cebu High-End <br/> Real Estate Scale.
            </h3>
            <p class="text-gray-400 font-light leading-relaxed max-w-md mb-12">
              Strategic Meta and Google Ads campaigns targeting high-net-worth individuals in Banilad and Mandaue. Achieved a 40% reduction in Cost Per Lead (CPL) for luxury residential properties.
            </p>
            <a href="#" class="group/btn flex items-center gap-4 text-xs uppercase tracking-[0.3em] font-bold">
              View Case Study 
              <span class="w-8 h-[1px] bg-white group-hover/btn:w-12 transition-all"></span>
            </a>
          </div>
          <div class="w-full lg:w-1/2 aspect-video lg:aspect-auto overflow-hidden bg-zinc-900">
            <img 
              src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?q=80&w=2340&auto=format&fit=crop" 
              alt="Cebu Real Estate Project" 
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 opacity-60 group-hover:opacity-100"
            />
          </div>
        </div>

        <div class="group relative w-full flex flex-col lg:flex-row-reverse border-b border-white/5 hover:bg-white/[0.02] transition-colors duration-500">
          <div class="flex-1 p-8 md:p-16 lg:p-24 flex flex-col justify-center">
            <span class="text-[#ff4d4d] font-mono text-sm mb-6 block tracking-widest uppercase">02 / Digital Marketing</span>
            <h3 class="text-4xl md:text-5xl lg:text-6xl font-medium tracking-tighter mb-8 leading-tight">
              E-Commerce <br/> ROAS Optimization.
            </h3>
            <p class="text-gray-400 font-light leading-relaxed max-w-md mb-12">
              Scaling e-commerce brands through precise Google Ads optimization and conversion tracking. Leveraged GA4 and GTM to increase attribution accuracy and drive 3.5x ROAS.
            </p>
            <a href="#" class="group/btn flex items-center gap-4 text-xs uppercase tracking-[0.3em] font-bold">
              View Case Study 
              <span class="w-8 h-[1px] bg-white group-hover/btn:w-12 transition-all"></span>
            </a>
          </div>
          <div class="w-full lg:w-1/2 aspect-video lg:aspect-auto overflow-hidden bg-zinc-900">
            <img 
              src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2426&auto=format&fit=crop" 
              alt="Digital Marketing Project" 
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 opacity-60 group-hover:opacity-100"
            />
          </div>
        </div>

      </div>
    </section>   
    
    </section>
    
    <section id="services" class="min-h-[50vh] flex items-center justify-center border-b border-white/5 text-white/30 text-2xl font-light">
    {/* ======================================================
        SECTION 8: SERVICES & SOLUTIONS
        ====================================================== */}
    <section id="services" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5 justify-center">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="absolute top-32 text-[#ff4d4d] text-5xl font-thin leading-none -left-[17px] hidden md:block">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase">My Expertise</div>
      </aside>

      <div class="w-full md:w-2/3 p-0 md:p-0 flex flex-col">
        
        <div class="group border-b border-white/5 p-12 lg:p-20 transition-colors duration-500 hover:bg-white/[0.02]">
          <div class="flex flex-col md:flex-row md:items-start justify-between gap-8">
            <div class="max-w-md">
              <span class="text-[#ff4d4d] font-mono text-xs mb-6 block tracking-widest uppercase">01 / Growth</span>
              <h3 class="text-3xl md:text-4xl font-medium tracking-tight mb-6">Performance Marketing & Paid Search</h3>
              <p class="text-gray-400 font-light leading-relaxed mb-8">
                Scaling businesses through high-intent Google Ads and Meta campaigns. Specialized in the Cebu real estate market and global e-commerce brands.
              </p>
              <div class="flex flex-wrap gap-3">
                <span class="px-3 py-1 border border-white/10 text-[10px] uppercase tracking-wider text-gray-500">Google Ads</span>
                <span class="px-3 py-1 border border-white/10 text-[10px] uppercase tracking-wider text-gray-500">Meta Ads</span>
                <span class="px-3 py-1 border border-white/10 text-[10px] uppercase tracking-wider text-gray-500">ROAS Scaling</span>
              </div>
            </div>
            <div class="hidden lg:block text-right">
              <div class="text-6xl font-thin opacity-5 group-hover:opacity-20 transition-opacity">PROFIT</div>
            </div>
          </div>
        </div>

        <div class="group border-b border-white/5 p-12 lg:p-20 transition-colors duration-500 hover:bg-white/[0.02]">
          <div class="flex flex-col md:flex-row md:items-start justify-between gap-8">
            <div class="max-w-md">
              <span class="text-[#ff4d4d] font-mono text-xs mb-6 block tracking-widest uppercase">02 / Analysis</span>
              <h3 class="text-3xl md:text-4xl font-medium tracking-tight mb-6">Conversion Tracking & Data Analysis</h3>
              <p class="text-gray-400 font-light leading-relaxed mb-8">
                Building robust tracking infrastructures using GTM and GA4. I turn raw data into actionable insights using Python and SQL for deeper attribution.
              </p>
              <div class="flex flex-wrap gap-3">
                <span class="px-3 py-1 border border-white/10 text-[10px] uppercase tracking-wider text-gray-500">GTM Server-Side</span>
                <span class="px-3 py-1 border border-white/10 text-[10px] uppercase tracking-wider text-gray-500">GA4 Audit</span>
                <span class="px-3 py-1 border border-white/10 text-[10px] uppercase tracking-wider text-gray-500">Python/SQL</span>
              </div>
            </div>
            <div class="hidden lg:block text-right">
              <div class="text-6xl font-thin opacity-5 group-hover:opacity-20 transition-opacity">INSIGHT</div>
            </div>
          </div>
        </div>

        <div class="group border-b border-white/5 p-12 lg:p-20 transition-colors duration-500 hover:bg-white/[0.02]">
          <div class="flex flex-col md:flex-row md:items-start justify-between gap-8">
            <div class="max-w-md">
              <span class="text-[#ff4d4d] font-mono text-xs mb-6 block tracking-widest uppercase">03 / Build</span>
              <h3 class="text-3xl md:text-4xl font-medium tracking-tight mb-6">Full-Stack Web Development</h3>
              <p class="text-gray-400 font-light leading-relaxed mb-8">
                Creating high-performance, SEO-optimized web applications and landing pages using Astro and Tailwind CSS. Built for speed and conversion.
              </p>
              <div class="flex flex-wrap gap-3">
                <span class="px-3 py-1 border border-white/10 text-[10px] uppercase tracking-wider text-gray-500">Astro Framework</span>
                <span class="px-3 py-1 border border-white/10 text-[10px] uppercase tracking-wider text-gray-500">Tailwind CSS</span>
                <span class="px-3 py-1 border border-white/10 text-[10px] uppercase tracking-wider text-gray-500">API Integration</span>
              </div>
            </div>
            <div class="hidden lg:block text-right">
              <div class="text-6xl font-thin opacity-5 group-hover:opacity-20 transition-opacity">CODE</div>
            </div>
          </div>
        </div>

      </div>
    </section>   
    
    </section>

       {/* ======================================================
        SECTION 7: BRANDS & PARTNERSHIPS
        ====================================================== */}
    <section id="brands" class="py-20 md:py-32 border-b border-white/5 overflow-hidden">
      <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-32">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
           <div class="max-w-xl">
             <span class="text-[#ff4d4d] font-mono text-sm mb-4 block tracking-widest uppercase">Global Partners</span>
             <h2 class="text-4xl md:text-5xl font-medium tracking-tighter leading-tight">
               Driving growth for industry leaders.
             </h2>
           </div>
           <p class="text-gray-400 font-light text-sm max-w-xs leading-relaxed">
             Specializing in scaling brands through data-driven performance marketing and conversion optimization.
           </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-1px bg-white/5 border border-white/5">
          
          <div class="group bg-[#0a0a0a] p-12 lg:p-16 flex flex-col items-center text-center transition-colors duration-500 hover:bg-white/[0.02]">
            <div class="h-24 flex items-center justify-center mb-10 grayscale group-hover:grayscale-0 transition-all duration-700 opacity-60 group-hover:opacity-100">
               <img src="/logos/blackout-audio.png" alt="Blackout Audio" class="max-h-full max-w-[180px] object-contain" />
            </div>
            <h4 class="text-white font-medium mb-3 tracking-tight">Blackout Audio</h4>
            <span class="text-[10px] text-[#ff4d4d] uppercase tracking-[0.2em] font-bold mb-6">E-Commerce & Google Ads</span>
            <p class="text-xs text-gray-500 font-light leading-relaxed">
              Optimized Shopify and Google Merchant Center integration to maximize sales volume and ROAS through precision campaign scaling.
            </p>
          </div>

          <div class="group bg-[#0a0a0a] p-12 lg:p-16 flex flex-col items-center text-center transition-colors duration-500 hover:bg-white/[0.02]">
            <div class="h-24 flex items-center justify-center mb-10 grayscale group-hover:grayscale-0 transition-all duration-700 opacity-60 group-hover:opacity-100">
               <img src="/logos/cocos-crush.png" alt="Coco's Crush Bar & Grill" class="max-h-full max-w-[180px] object-contain" />
            </div>
            <h4 class="text-white font-medium mb-3 tracking-tight">Coco's Crush Bar & Grill</h4>
            <span class="text-[10px] text-[#ff4d4d] uppercase tracking-[0.2em] font-bold mb-6">Foot Traffic Optimization</span>
            <p class="text-xs text-gray-500 font-light leading-relaxed">
              Implemented high-intent audience segmenting to drive physical restaurant visits while maintaining a strict lower-cost-per-acquisition.
            </p>
          </div>

          <div class="group bg-[#0a0a0a] p-12 lg:p-16 flex flex-col items-center text-center transition-colors duration-500 hover:bg-white/[0.02]">
            <div class="h-24 flex items-center justify-center mb-10 grayscale group-hover:grayscale-0 transition-all duration-700 opacity-60 group-hover:opacity-100">
               <img src="/logos/porcelanosa.png" alt="Porcelanosa" class="max-h-full max-w-[180px] object-contain" />
            </div>
            <h4 class="text-white font-medium mb-3 tracking-tight">Porcelanosa</h4>
            <span class="text-[10px] text-[#ff4d4d] uppercase tracking-[0.2em] font-bold mb-6">Lead Gen & CRO</span>
            <p class="text-xs text-gray-500 font-light leading-relaxed">
              Analyzed user behaviors to maximize site visits and lead generation for high-end Spanish home fixtures and surfaces.
            </p>
          </div>

        </div>
      </div>
    </section>

    {/* SECTION 5: CONTACT */}
   {/* ======================================================
        SECTION 9: CONTACT & INQUIRIES
        ====================================================== */}
    <section id="contact" class="min-h-screen flex flex-col md:flex-row relative">
      
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5 justify-center">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="absolute top-32 text-[#ff4d4d] text-5xl font-thin leading-none -left-[17px] hidden md:block">+</div>
        
        <div class="mb-12">
            <span class="text-sm opacity-60 tracking-[0.2em] uppercase block mb-4">Contact</span>
            <h2 class="text-4xl md:text-5xl font-medium tracking-tighter leading-tight mb-8">
              Let’s build <br/> something great.
            </h2>
            <p class="text-gray-400 font-light leading-relaxed max-w-xs">
              Available for freelance projects and full-time opportunities in Performance Marketing and Web Development.
            </p>
        </div>

        <div class="space-y-6">
