---
import Layout from '../layouts/Layout.astro';
import profileImage from '../assets/photos/profile.png';
import SkillsGrid from '../components/SkillsGrid.astro';

// We define your menu items and their target IDs here
const menuItems = [
  { name: 'about me', link: '#about' },
  { name: 'work experience', link: '#experience' },
  { name: 'personal skills', link: '#skills' },
  { name: 'portfolio', link: '#portfolio' },
  { name: 'services', link: '#services' },
  { name: 'contact', link: '#contact' }
];
---

<Layout title="Alberry Jed Rivera | Portfolio">
  <main class="bg-[#0a0a0a] text-[#f4f4f4] font-sans selection:bg-[#ff4d4d] selection:text-white overflow-x-hidden">
    
    {/* SECTION 1: HERO */}
    <section id="hero" class="min-h-screen relative flex flex-col justify-center px-8 md:px-10 lg:px-32 border-b border-white/5 pt-24 md:pt-0">
      
      <div class="absolute top-8 md:top-12 left-8 md:left-10 lg:left-32 inline-flex items-center gap-3 px-4 py-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm z-20">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        <span class="text-[10px] uppercase tracking-[0.2em] font-bold opacity-80 mt-[1px]">Available for new projects</span>
      </div>

      <div class="relative z-10 max-w-6xl mt-10 md:mt-20">
        <h1 class="text-[14vw] md:text-[12vw] lg:text-[7vw] font-medium leading-[0.9] tracking-tighter">
          Full Stack <br/> Web Development, <br/> Data Analysis & <br/> Digital Marketing.
        </h1>
      </div>

      <div class="hidden lg:flex absolute right-20 top-0 bottom-0 flex-col items-center py-12 z-20">
        <div class="text-[#ff4d4d] text-5xl font-thin leading-none">+</div>
        <div class="flex-1 w-[1px] bg-white/20 my-8"></div>
        <div class="[writing-mode:vertical-rl] rotate-180 text-sm tracking-[0.4em] uppercase opacity-70 whitespace-nowrap">
          Alberry Jed Rivera
        </div>
      </div>
    </section>

    {/* SECTION 2: TABLE OF CONTENTS */}
    <section id="toc" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="mt-8 md:mt-32 text-[#ff4d4d] text-5xl font-thin leading-none mb-8 md:mb-16 relative md:-left-[17px]">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase leading-loose">
          Table of <br/> Contents
        </div>
      </aside>

      <div class="w-full md:w-2/3 p-8 md:p-10 lg:p-32 flex flex-col justify-center">
        <p class="text-lg md:text-xl font-light text-gray-400 leading-relaxed max-w-2xl mb-16 md:mb-24">
          Full spectrum of technical and marketing solutions to aspiring and established brands. Create and implement effective strategies that boost sales and engagement. Business owners can focus on running their operations while I build the systems, analyze the data, and manage the digital marketing needs.
        </p>

        <ul class="space-y-6 text-3xl md:text-4xl lg:text-6xl font-light tracking-tight">
          {menuItems.map((item) => (
            <li>
              <a href={item.link} class="group flex items-center gap-6 md:gap-8 hover:text-white text-gray-500 transition-colors w-fit">
                <span class="text-white/10 font-mono text-4xl md:text-5xl group-hover:text-white transition-colors font-thin">+</span> 
                <span class="group-hover:translate-x-4 transition-transform duration-500">{item.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* SECTION 3: ABOUT ME */}
    <section id="about" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5 justify-center">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="hidden md:block absolute top-32 text-[#ff4d4d] text-5xl font-thin leading-none -left-[17px]">+</div>
        <div class="md:hidden text-[#ff4d4d] text-5xl font-thin leading-none mb-4">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase">About me</div>
      </aside>

      <div class="w-full md:w-2/3 p-8 md:p-10 lg:p-32 flex flex-col lg:flex-row gap-12 md:gap-20 items-center">
        
        <div class="flex-1 order-2 lg:order-1">
          <div class="flex items-start gap-4 mb-10 md:mb-16">
            <div class="w-3 h-3 bg-[#ff4d4d] mt-2 flex-shrink-0"></div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight leading-tight">
              Algorithm Precision. <br/> Creative Fix. <br/> Breakthrough Results.
            </h2>
          </div>
          <p class="text-base md:text-lg font-light text-gray-400 leading-relaxed">
            A multidisciplinary professional who can manage the technical, analytical, and marketing aspects of your business. Planning and delivering full-stack solutions, analyzing market trends, and executing campaigns that propel your brand to new heights.
          </p>
        </div>

        <div class="w-full lg:w-96 flex-shrink-0 order-1 lg:order-2">
          <div class="aspect-[3/4] bg-zinc-900 overflow-hidden relative group">
            <img 
              src={profileImage.src} 
              alt="Alberry Jed Rivera" 
              class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700" 
            />
          </div>
          <h3 class="text-2xl md:text-3xl font-medium mt-6">Alberry Jed Rivera</h3>
          <p class="text-xs md:text-sm opacity-60 tracking-widest uppercase mt-2">Web Dev / Data / Marketing</p>
        </div>

      </div>
    </section>

    {/* SECTION 4: EXPERIENCE */}
    <section id="experience" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5 justify-center">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="hidden md:block absolute top-32 text-white text-5xl font-thin leading-none -left-[17px]">+</div>
        <div class="md:hidden text-white text-5xl font-thin leading-none mb-4">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase">Experience</div>
      </aside>

      <div class="w-full md:w-2/3 p-8 md:p-10 lg:p-32 flex flex-col justify-center">
        <div class="space-y-12 md:space-y-16">
          
          <div class="flex items-start gap-6 md:gap-8">
            <div class="text-[#ff4d4d] text-3xl md:text-4xl font-thin mt-1">+</div>
            <div>
              <h3 class="text-2xl md:text-3xl lg:text-4xl font-medium mb-2">Administrative Growth Assistant</h3>
              <p class="text-base md:text-lg opacity-60 font-light">Talentpop, 2026 – Present</p>
            </div>
          </div>

          <div class="flex items-start gap-6 md:gap-8">
            <div class="text-[#ff4d4d] text-3xl md:text-4xl font-thin mt-1">+</div>
            <div>
              <h3 class="text-2xl md:text-3xl lg:text-4xl font-medium mb-2">Google Ads Strategist</h3>
              <p class="text-base md:text-lg opacity-60 font-light">Concentrix, 2024 – 2026</p>
            </div>
          </div>

		  <div class="flex items-start gap-6 md:gap-8">
            <div class="text-[#ff4d4d] text-3xl md:text-4xl font-thin mt-1">+</div>
            <div>
              <h3 class="text-2xl md:text-3xl lg:text-4xl font-medium mb-2">Business Development Associate</h3>
              <p class="text-base md:text-lg opacity-60 font-light">Accenture, 2021 – 2024</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    {/* PLACEHOLDER SECTIONS (So the links work!) */}
    {/* SECTION 5: PERSONAL SKILLS */}
    <section id="skills" class="min-h-screen flex flex-col md:flex-row relative border-b border-white/5">
      
      <aside class="w-full md:w-1/3 p-8 md:p-10 lg:p-32 flex flex-col relative md:border-r border-white/5 justify-center">
        <div class="hidden md:block absolute left-32 top-0 w-[1px] h-32 bg-white"></div>
        <div class="hidden md:block absolute top-32 text-[#ff4d4d] text-5xl font-thin leading-none -left-[17px]">+</div>
        <div class="md:hidden text-[#ff4d4d] text-5xl font-thin leading-none mb-4">+</div>
        <div class="text-sm opacity-60 tracking-[0.2em] uppercase">Personal Skills</div>
      </aside>

      <div class="w-full md:w-2/3 p-8 md:p-10 lg:p-32 flex flex-col justify-center items-center">
        <div class="max-w-3xl text-center mb-16">
           <h2 class="text-3xl md:text-4xl font-medium mb-6">A Full-Stack Arsenal.</h2>
           <p class="text-gray-400 font-light leading-relaxed">
             My expertise spans the entire digital lifecycle. From architecting robust web applications and analyzing complex datasets to executing high-ROI marketing campaigns, I have the right tool for every challenge.
           </p>
        </div>

        <SkillsGrid />
        
      </div>
    </section>
    
    <section id="portfolio" class="min-h-[50vh] flex items-center justify-center border-b border-white/5 text-white/30 text-2xl font-light">
       </section>
    
    <section id="services" class="min-h-[50vh] flex items-center justify-center border-b border-white/5 text-white/30 text-2xl font-light">
       </section>

    {/* SECTION 5: CONTACT */}
    <section id="contact" class="min-h-[70vh] flex flex-col items-center justify-center relative py-20 md:py-32 overflow-hidden px-8">
      
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-[#ff4d4d]/5 blur-[80px] md:blur-[120px] rounded-full pointer-events-none"></div>

      <h2 class="text-4xl md:text-5xl lg:text-[8vw] font-medium tracking-tighter mb-10 md:mb-16 text-center relative z-10 leading-none">
        Let's Connect.
      </h2>

      <div class="flex flex-col sm:flex-row gap-4 md:gap-6 z-10 w-full sm:w-auto">
        
        <a href="https://www.linkedin.com/in/alberry-jed-rivera-89853994/" target="_blank" rel="noopener noreferrer" class="group relative flex items-center justify-center gap-4 px-8 md:px-10 py-4 md:py-5 rounded-full border border-white/20 bg-transparent overflow-hidden transition-all duration-500 hover:border-white">
          <div class="absolute inset-0 bg-white translate-y-[100%] group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]"></div>
          <svg class="w-5 h-5 text-white group-hover:text-black relative z-10 transition-colors duration-500" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
          <span class="text-white group-hover:text-black relative z-10 tracking-[0.2em] uppercase text-[10px] md:text-xs font-bold transition-colors duration-500">LinkedIn</span>
        </a>

        <a href="mailto:alberryjed1@gmail.com" class="group relative flex items-center justify-center gap-4 px-8 md:px-10 py-4 md:py-5 rounded-full border border-white/20 bg-transparent overflow-hidden transition-all duration-500 hover:border-[#ff4d4d]">
          <div class="absolute inset-0 bg-[#ff4d4d] translate-y-[100%] group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]"></div>
          <svg class="w-5 h-5 md:w-6 md:h-6 text-white relative z-10 transition-colors duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
          <span class="text-white relative z-10 tracking-[0.2em] uppercase text-[10px] md:text-xs font-bold transition-colors duration-500">Email Me</span>
        </a>

      </div>
    </section>

  </main>
</Layout>